# ملف إعدادات الانتاج ل Vercel
# هذه القيم سيتم جلبها تلقائياً من متغيرات البيئة في Vercel

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# بعد إنشاء قاعدة بيانات PostgreSQL على Vercel، قم بنسخ رابط الاتصال هنا
# مثال:
# DATABASE_URL=postgresql://postgres:xxxxxxxxxxxx@ep-xxxxxx-xxxxxx-xxxxxx.us-east-1.aws.neon.tech/verceldb?sslmode=require

PORT=4000
NODE_ENV=production